# copy to .env.local and fill in your values (gitignored)
# .env.local is never committed — add it to .gitignore if it isn't already.

# --- Kubernetes ---
export KUBECONFIG=~/.kube/config
export NICO_CONTEXT=my-cluster        # optional: omit to use current kubeconfig context
export NICO_NAMESPACE=nico

# --- Reach mode ---
# auto-detect (default): port-forward if no KUBERNETES_SERVICE_HOST, in-cluster if set.
# Override: export NICO_REACH_MODE=port-forward   # or in-cluster
# export NICO_REACH_MODE=port-forward

# --- Temporal ---
# Only needed if port-forward auto-detect cannot find the Temporal service, or if you
# want to skip port-forwarding entirely and supply an already-forwarded address.
export NICO_TEMPORAL_ADDRESS=localhost:7233
export NICO_TEMPORAL_NAMESPACE=default

# --- Postgres ---
# Only needed if port-forward auto-detect cannot find the Postgres service, or if you
# want to supply an already-forwarded DSN.
export NICO_POSTGRES_URL=postgres://nico:secret@localhost:5432/nico

# --- Loki (optional) ---
export LOKI_URL=http://localhost:3100

# --- HTTP health endpoints (optional) ---
# Comma-separated list of name=URL pairs for the nico-doctor health layer.
export NICO_HEALTH_ENDPOINTS="rest=http://localhost:8080,core=http://localhost:9090"

# --- Smoke test ---
# A known recent workflow ID (UUID or hp-* prefix) used to exercise nico-correlate.
export SMOKE_WORKFLOW_ID=<a known recent workflow ID>
